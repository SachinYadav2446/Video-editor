# Server environment configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
JWT_SECRET=cinecut_super_secret_jwt_key_2025_premium

# PostgreSQL Database
# Using Neon.tech free PostgreSQL cloud database (instant setup, no install required)
# Replace with your own PostgreSQL DATABASE_URL if you prefer
